names(df)
df %>%
filter(ratio >= 0.3) %>%
select(FG1, FG2, FG3) %>%
head()
158 + 161 + 190
df2 <- df %>%
mutate(run = row_number(),
diff = smallestFG1 - (509/3),
adj_diff = if_else(ratio >= 0.15, -diff, diff))
ggplot(df2, aes(x = factor(run), y = adj_diff)) +
geom_col(fill = "steelblue") +
geom_hline(yintercept = 0, color = "black") +
labs(x = "Run", y = "Individuals (adjusted)") +
theme_minimal() +
theme(axis.text.x = element_text(angle = 90, vjust = 0.5, hjust=1))
range(df2$adj_diff)
