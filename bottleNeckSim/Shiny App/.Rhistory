df2 <- df %>%
filter(!is.na(HapDiv)) %>%
mutate(run = row_number())
# calculate scaling factors outside of ggplot
scale_factor <- max(df2$ratio, na.rm = TRUE) / max(df2$HapDiv, na.rm = TRUE)
ggplot(df2, aes(x = run)) +
geom_line(aes(y = ratio, color = "ratio")) +
geom_line(aes(y = HapDiv * scale_factor, color = "HapDiv")) +
scale_y_continuous(
name = "ratio",
sec.axis = sec_axis(~ . / scale_factor, name = "HapDiv")
) +
scale_color_manual(
name = "Feature",
values = c("ratio" = "blue", "HapDiv" = "red")
) +
theme_minimal() +
theme(
axis.title.y.left = element_text(color = "blue"),
axis.title.y.right = element_text(color = "red")
)
df2 <- df %>%
filter(!is.na(HapDiv)) %>%
mutate(run = row_number())
# precompute scale factor
scale_factor <- max(df2$ratio, na.rm = TRUE) / max(df2$HapDiv, na.rm = TRUE)
ggplot(df2, aes(x = run)) +
geom_line(aes(y = ratio), color = "blue", size = 1) +
geom_line(aes(y = HapDiv * scale_factor), color = "red", size = 1) +
scale_y_continuous(
name = "ratio",
sec.axis = sec_axis(~ . / scale_factor, name = "HapDiv")
) +
theme_minimal() +
theme(
axis.title.y.left = element_text(color = "blue"),
axis.title.y.right = element_text(color = "red")
)
ggplot(df2, aes(x = run)) +
geom_line(aes(y = ratio), color = "blue", size = 1) +
#geom_line(aes(y = HapDiv * scale_factor), color = "red", size = 1) +
scale_y_continuous(
name = "ratio",
sec.axis = sec_axis(~ . / scale_factor, name = "HapDiv")
) +
theme_minimal() +
theme(
axis.title.y.left = element_text(color = "blue"),
#axis.title.y.right = element_text(color = "red")
)
ggplot(df2, aes(x = run, y = ratio)) +
# background zones
annotate("rect", xmin = -Inf, xmax = Inf, ymin = 0,     ymax = 0.01,
fill = "red", alpha = 0.15) +
annotate("rect", xmin = -Inf, xmax = Inf, ymin = 0.01, ymax = 0.15,
fill = "yellow", alpha = 0.15) +
annotate("rect", xmin = -Inf, xmax = Inf, ymin = 0.15, ymax = Inf,
fill = "green", alpha = 0.15) +
# ratio line
geom_line(color = "blue", size = 1) +
scale_y_continuous(name = "ratio") +
theme_minimal()
df2 <- df %>%
mutate(run = row_number(),
zone = case_when(
ratio <= 0.01 ~ "≤1%",
ratio <= 0.15 ~ "1–15%",
TRUE          ~ "≥15%"
))
ggplot(df2, aes(x = run, y = ratio, color = zone)) +
geom_point(size = 2) +
scale_color_manual(
values = c("≤1%" = "red", "1–15%" = "orange", "≥15%" = "green")
) +
scale_y_continuous(name = "ratio") +
theme_minimal() +
theme(legend.title = element_blank())
