df2 <- df %>%
mutate(run = row_number(),
diff = smallestFG1 - (509/3),
adj_diff = diff,
bar_color = case_when(
ratio <= 0.01 ~ "green",
ratio <= 0.05 ~ "orange",
ratio <= 0.10 ~ "yellow",
TRUE          ~ "steelblue"
))
ggplot(df2, aes(x = run, y = adj_diff, fill = bar_color)) +
geom_col() +
geom_hline(yintercept = 0, color = "black") +
labs(x = "Run", y = "Individuals (adjusted)") +
scale_fill_identity() +  # use actual colors from bar_color
scale_x_continuous(
breaks = c(0, 10000, 20000, 30000)  # sparse ticks
) +
theme_minimal()
