range(data$HapDiv, na.rm = T)
# add run number
df <- data
df$run <- seq_len(nrow(df))
#### plot FG loss
library(ggplot2)
ggplot(df, aes(x = run)) +
geom_line(aes(y = ratio, color = "ratio")) +
geom_line(aes(y = hapDiv * (max(df$ratio)/max(df$hapDiv)), color = "hapDiv")) +
scale_y_continuous(
name = "ratio",
sec.axis = sec_axis(~ . * (max(df$hapDiv)/max(df$ratio)), name = "hapDiv")
) +
scale_color_manual(
name = "Feature",
values = c("ratio" = "blue", "hapDiv" = "red")
) +
theme_minimal() +
theme(
axis.title.y.left = element_text(color = "blue"),
axis.title.y.right = element_text(color = "red")
)
